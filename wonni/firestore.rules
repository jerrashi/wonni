rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Catalog items ─────────────────────────────────────────────────────────
    // Readable by all authenticated users.
    // Writes are server-side only (Cloud Functions) — clients cannot write directly.
    match /catalog/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Promotions (Banners) ──────────────────────────────────────────────────
    match /promotions/{promotionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Inventory units ───────────────────────────────────────────────────────
    match /inventory/{unitId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── Listings ──────────────────────────────────────────────────────────────
    // Readable by all authenticated users (buyers need to browse).
    // Only the listing owner can write.
    match /listings/{listingId} {
      // Readable by all if not a draft, or if the user is the owner
      allow read: if request.auth != null && (
                    resource.data.status != "draft" || request.auth.uid == resource.data.userId
                  );
      allow write: if request.auth != null
                   && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    // Participants only. Buyers can create; both parties can update (send messages).
    match /conversations/{conversationId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // ── User profiles and subcollections ─────────────────────────────────────
    // Profile document: readable by all authenticated users, writable by owner.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   // If they are setting a username, it must either be unchanged or they must own it in the usernames collection.
                   // Since they create the username doc in the same batch, we check getAfter.
                   && (!request.resource.data.keys().hasAny(['username']) 
                       || request.resource.data.username == null
                       || (resource != null && request.resource.data.username == resource.data.username)
                       || getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.userId == request.auth.uid);

      // Saved listings — private to each user
      match /saved/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Custom lists (e.g. Wishlist, Gift Ideas) — private to each user
      match /lists/{listId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Watchlist (existing)
      match /watchlist/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Search history — private, auto-populated on search
      match /searchHistory/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Saved searches — private, user-bookmarked queries
      match /savedSearches/{searchId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }

  // Trending searches — read-only for authenticated users; admin writes only
  match /trending/{trendId} {
    allow read: if request.auth != null;
    allow write: if false;
  }

  // ── Usernames (For Uniqueness Enforcement) ──────────────────────────────
  // The document ID is the lowercase username. Data must contain { userId: <uid> }.
  match /usernames/{username} {
    allow read: if request.auth != null;
    
    // Can only claim if the username does not exist (enforces uniqueness)
    // and the userId in the document matches the authenticated user.
    allow create: if request.auth != null
                  && request.resource.data.userId == request.auth.uid
                  && !exists(/databases/$(database)/documents/usernames/$(username));
                  
    // Can delete if the authenticated user owns this username.
    allow delete: if request.auth != null 
                  && resource.data.userId == request.auth.uid;
                  
    // Cannot update ownership directly. Must delete and recreate.
    allow update: if false;
  }
}
