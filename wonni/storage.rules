rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — owner writes, all authenticated users read
    match /users/{userId}/profile.jpg {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Listing photos — owner writes, any authenticated user can read.
    // Note: we intentionally do NOT do a Firestore cross-service read here
    // because it adds latency and can deny access when the listing document
    // hasn't been written yet (e.g. during the upload pipeline). Draft photo
    // paths are never exposed to other users via the client app, so this is safe.
    match /users/{userId}/{listingId}/{imageId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Catalog reference photos — read-only for clients, written server-side only
    match /catalog/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
