rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — owner writes, all authenticated users read
    match /users/{userId}/profile.jpg {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Listing photos — owner writes, others can read ONLY if the listing is not a draft
    match /users/{userId}/{listingId}/{imageId} {
      allow read:  if request.auth != null && (
                     request.auth.uid == userId ||
                     firestore.get(/databases/(default)/documents/listings/$(listingId)).data.status != "draft"
                   );
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Catalog reference photos — read-only for clients, written server-side only
    match /catalog/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
