rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — owner writes, authenticated users read (personal data)
    match /users/{userId}/profile.jpg {
      allow read:  if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Listing photos — publicly readable so Google Shopping ads, shared links,
    // and unauthenticated web/app traffic can all load images.
    // Owner writes only; size-capped at 10 MB.
    match /users/{userId}/{listingId}/{imageId} {
      allow read:  if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // Catalog reference photos — read-only for clients, written server-side only
    match /catalog/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
